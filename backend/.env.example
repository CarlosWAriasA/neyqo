NODE_ENV=development
PORT=3000
APP_URL=
FRONTEND_URL=

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neyqo
DB_SSL=false
DB_SYNCHRONIZE=true

ALLOWED_ORIGINS=http://app.localhost:4200,http://app.localhost:8080,http://localhost:4200,http://localhost:5173,http://localhost:8080

JWT_ACCESS_SECRET=change-this-access-secret-with-at-least-32-characters
JWT_REFRESH_SECRET=change-this-refresh-secret-with-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_COOKIE_NAME=refresh_token

COOKIE_SECURE=true
COOKIE_SAME_SITE=none
COOKIE_DOMAIN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_AUTH_REDIRECT_URI=
GOOGLE_GMAIL_REDIRECT_URI=http://localhost:3000/api/sync/oauth/gmail/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_AUTH_REDIRECT_URI=
MICROSOFT_MAIL_REDIRECT_URI=

EXTERNAL_TOKEN_ENCRYPTION_KEY=
INTERNAL_SERVICE_SECRET=

EMAIL_VERIFICATION_CODE_EXPIRES_MINUTES=15
PASSWORD_RESET_CODE_EXPIRES_MINUTES=15

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Neyqo
MAIL_DEV_LOG_CODES=true
FILE_LOGGING_ENABLED=true
LOG_DIR=logs

TRUST_PROXY=false
API_BODY_LIMIT_BYTES=262144
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_WRITE_RATE_LIMIT_MAX=20
AUTH_CODE_RATE_LIMIT_MAX=8
AUTH_REFRESH_RATE_LIMIT_MAX=60
AUTH_RATE_LIMIT_WINDOW=1 minute
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_WINDOW_MINUTES=15
AUTH_LOCKOUT_BASE_SECONDS=30

EXCHANGE_RATES_API_BASE_URL=https://api.frankfurter.dev
