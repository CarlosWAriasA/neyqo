NODE_ENV=development
PORT=3010

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neyqo
DB_SSL=false

WORKER_ENABLED=true
WORKER_INSTANCE_ID=
NEYQO_API_BASE_URL=http://localhost:3000
INTERNAL_SERVICE_SECRET=

SCHEDULED_TRANSACTIONS_JOB_ENABLED=true
SCHEDULED_TRANSACTIONS_INTERVAL_MINUTES=10
SCHEDULED_TRANSACTIONS_BATCH_SIZE=100
SCHEDULED_TRANSACTIONS_MAX_CATCH_UP_PER_RECORD=100
SCHEDULED_TRANSACTIONS_LOCK_TTL_SECONDS=120

EMAIL_SYNC_JOB_ENABLED=false
EMAIL_SYNC_INTERVAL_MINUTES=10
EMAIL_SYNC_BATCH_SIZE=50
EXTERNAL_TOKEN_ENCRYPTION_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

JOB_MAX_RETRIES=3
JOB_RETRY_DELAY_SECONDS=30
